<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Historial Mensual — Replay</title>
  <link rel="stylesheet" href="../styles.css" />
</head>
<body>
  <main class="page">
    <a href="../index.html" class="back-btn">← Volver</a>
    <h2 class="title" style="font-size:32px;color:var(--pink);font-weight:700">📝 Registrar Nuevo Mes</h2>
    <hr style="border:none;border-top:3px solid var(--pink);margin:16px 0 24px 0" />
    
    <div class="container">
      <!-- Campo 1: Mes -->
      <div class="history-card">
        <label class="history-label">Mes *</label>
        <input id="history-month" type="text" class="history-input" placeholder="Noviembre" />
      </div>

      <!-- Campo 2: Año -->
      <div class="history-card">
        <label class="history-label">Año *</label>
        <input id="history-year" type="number" class="history-input" placeholder="2024" />
      </div>

      <!-- Campo 3: Información de Alumnos -->
      <div class="history-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <label class="history-label" style="margin:0">Información de Alumnos Inscritos</label>
          <label class="history-label-secondary">Pagos Recibidos</label>
        </div>
        <textarea id="history-students" class="history-textarea" rows="5" placeholder="Ej: 20 personas inscritas en todas las disciplinas. Total recaudado: $7,000. María se inscribió..."></textarea>
      </div>

      <!-- Campo 4: Información de Rentas -->
      <div class="history-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <label class="history-label" style="margin:0">Información de Rentas</label>
          <label class="history-label-secondary">Pagos Recibidos</label>
        </div>
